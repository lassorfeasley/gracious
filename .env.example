# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — verify the gracious.host domain in Resend, then send as hello@
RESEND_API_KEY=re_your_api_key
RESEND_FROM=Gracious <hello@gracious.host>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-random-cron-secret

# Stripe
# Pro prices are resolved at runtime via Stripe Price "lookup keys"
# (pro_annual / pro_monthly) — attach those keys to your prices in the Stripe
# dashboard. No price_... IDs needed here; the same keys work in test and live.
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Supabase Auth "Send Email" hook secret (Dashboard → Auth → Hooks → Send Email).
# Used to verify Supabase calls to /api/auth/email-hook. Format: v1,whsec_...
SEND_EMAIL_HOOK_SECRET=v1,whsec_your_hook_secret

# Secret used to sign one-click email unsubscribe links. Optional — falls back
# to SUPABASE_SERVICE_ROLE_KEY if unset. Use any long random string.
EMAIL_UNSUBSCRIBE_SECRET=your-random-unsubscribe-secret

# Site admin (comma-separated emails with /admin access in addition to users
# flagged is_admin in the DB). Bootstraps access before the flag is set.
SITE_ADMIN_EMAILS=you@example.com

# Dev only: set to 1 to let any signed-in user open /admin (for styling the
# admin UI). Leave unset so local dev enforces real admin gating.
DEV_ADMIN_PREVIEW=

# Dev toolbar: default invite token for Guest view (optional)
NEXT_PUBLIC_DEV_INVITE_TOKEN=

# Mapbox (public token, pk.*) — powers the property location map
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token
