# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_FROM=GuestHouse <noreply@yourdomain.com>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-random-cron-secret

# Site admin (comma-separated emails with /admin access before DB role is set)
SITE_ADMIN_EMAILS=you@example.com

# Dev toolbar: default invite token for Guest view (optional)
NEXT_PUBLIC_DEV_INVITE_TOKEN=

# Mapbox (public token, pk.*) — powers the property location map
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token
